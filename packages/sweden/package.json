  "type": "module",
  "keywords": [
    "sweden",
    "personnummer",
    "samordningsnummer",
    "organisationsnummer",
    "swedish-id",
    "identity",
    "validation",
    "luhn",
    "typescript"
  ],
  "homepage": "https://github.com/crippledgeek/civitas-id#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/crippledgeek/civitas-id.git",
    "directory": "packages/sweden"
  },
  "bugs": {
    "url": "https://github.com/crippledgeek/civitas-id/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
